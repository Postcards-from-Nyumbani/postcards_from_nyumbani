---
// src/components/Postcard.astro
import { Image } from 'astro:assets';
import { formatPostmark, ROOMS, type Room } from '../lib/collections';

interface Props {
  title:       string;
  description: string;
  date:        Date;
  room:        Room;
  slug:        string;
  cover?:      any; 
  tags?:       string[];
  author?:     string;  
  mood?:       string;  
  medium?:     string;  
}

const {
  title,
  description,
  date,
  room,
  slug,
  cover,
  tags = [],
  author,
  mood,
  medium,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const roomMeta   = ROOMS[room];
const postmark   = formatPostmark(date);
const href       = `${base}/${room}/${slug}/`;
const stampClass = `stamp--${room}`;

// Check if this card actually has an image to display
const hasImage = !!cover;
---

<article class={`postcard group ${hasImage ? 'postcard--has-cover' : 'postcard--text-only'}`} data-room={room}>
  <a href={href} class="postcard__link" aria-label={`Read: ${title}`}>

    {/* ONLY render the image wrap if there is a cover photo */}
    {hasImage && (
      <div class="postcard__image-wrap">
        <Image
          src={cover}
          alt={title}
          width={600}
          height={400}
          class="postcard__image"
          loading="lazy"
          decoding="async"
        />
        <div class="postcard__date-badge">
          <time datetime={date.toISOString()} class="postcard__date">
            {postmark}
          </time>
        </div>
      </div>
    )}

    <div class="postcard__body">
      <div class="postcard__stamp-row">
        <span class={`stamp ${stampClass}`}>
          {roomMeta.label}
        </span>
        
        {/* If there is no image, we move the date down here so it isn't lost! */}
        {!hasImage && (
          <span class="postcard__meta-pill">{postmark}</span>
        )}

        {medium && (
          <span class="postcard__meta-pill">{medium}</span>
        )}
        {mood && (
          <span class="postcard__meta-pill">#{mood}</span>
        )}
      </div>

      <h2 class="postcard__title">{title}</h2>

      {author && (
        <p class="postcard__author">— {author}</p>
      )}

      <p class="postcard__snippet">{description}</p>

      {tags.length > 0 && (
        <div class="postcard__tags">
          {tags.map(tag => (
            <span class="postcard__tag">#{tag}</span>
          ))}
        </div>
      )}

      <div class="postcard__footer">
        <span class="postcard__read-more">
          Continue reading
          <svg class="postcard__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M2 7H12M8 3L12 7L8 11" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </div>

    </div>
  </a>
</article>

<style>
  .postcard {
    background-color: theme('colors.parchment');
    border-radius: theme('borderRadius.postcard');
    box-shadow: theme('boxShadow.card');
    overflow: hidden;
    position: relative;
    transition:
      transform    0.3s theme('transitionTimingFunction.museum'),
      box-shadow   0.3s theme('transitionTimingFunction.museum');
    break-inside: avoid;
  }

  .postcard:hover {
    transform: translateY(-3px) rotate(0.25deg);
    box-shadow: theme('boxShadow.card-hover');
  }

  /* Specific styling for pure text cards */
  .postcard--text-only {
    border-top: 4px solid theme('colors.postmark');
  }

  .postcard__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .postcard__image-wrap {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background-color: theme('colors.vellum');
    border-bottom: 1px solid theme('colors.vellum');
  }

  .postcard__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s theme('transitionTimingFunction.museum');
  }

  .postcard:hover .postcard__image {
    transform: scale(1.03);
  }

  .postcard__date-badge {
    position: absolute;
    bottom: 0;
    right: 0;
    background-color: rgba(253, 252, 240, 0.88);
    backdrop-filter: blur(4px);
    padding: 4px 10px;
    border-top-left-radius: 2px;
  }

  .postcard__date {
    font-family: theme('fontFamily.mono');
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    color: theme('colors.dust');
    display: block;
  }

  .postcard__body {
    padding: 1.25rem 1.35rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 1;
  }

  .postcard__stamp-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .postcard__meta-pill {
    font-family: theme('fontFamily.sans');
    font-size: 0.65rem;
    color: theme('colors.dust');
    letter-spacing: 0.06em;
  }

  .postcard__title {
    font-family: theme('fontFamily.serif');
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.35;
    color: theme('colors.charcoal');
    letter-spacing: -0.01em;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .postcard__author {
    font-family: theme('fontFamily.serif');
    font-style: italic;
    font-size: 0.875rem;
    color: theme('colors.sepia');
    margin: 0;
  }

  .postcard__snippet {
    font-family: theme('fontFamily.serif');
    font-size: 0.9rem;
    line-height: 1.65;
    color: theme('colors.sepia');
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .postcard__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.1rem;
  }

  .postcard__tag {
    font-family: theme('fontFamily.sans');
    font-size: 0.68rem;
    color: theme('colors.dust');
    letter-spacing: 0.04em;
  }

  .postcard__footer {
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid theme('colors.vellum');
  }

  .postcard__read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: theme('fontFamily.sans');
    font-size: 0.73rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: theme('colors.dust');
    transition: color 0.2s ease;
  }

  .postcard:hover .postcard__read-more {
    color: theme('colors.postmark');
  }

  .postcard__arrow {
    transition: transform 0.2s ease;
  }

  .postcard:hover .postcard__arrow {
    transform: translateX(3px);
  }
</style>